# Redirections https antoine-mazoyer.fr
RewriteEngine On
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteCond %{HTTPS} !on
RewriteCond %{HTTP_HOST} ^(?:www\.)?antoine-mazoyer\.fr(?:.*)$ [nc]
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [redirect=301,L]
RewriteRule ^accueil$                    controller/home.php [L]
RewriteRule ^competences$                controller/skills.php [L]
RewriteRule ^projets&veille_techno$      controller/projects.php [L]
RewriteRule ^cv$                         controller/cv.php [L]

